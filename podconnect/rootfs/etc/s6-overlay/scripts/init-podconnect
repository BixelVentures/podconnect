#!/usr/bin/with-contenv bashio
set -e
# Global, room-agnostic setup only. The PER-ROOM config (go-librespot config.yml + owntone.conf +
# device_id) is now rendered by the manager (see manager/render.go) so rooms can be added live with
# no add-on restart. This script just prepares the shared filesystem + mDNS, then the manager (an
# s6 longrun that depends on avahi) forks + supervises each room's children.
OPTS=/data/options.json
[ -f "$OPTS" ] || echo '{}' > "$OPTS"

# Shared dirs. /data/go-librespot + /data/owntone are room 0's LEGACY paths (preserved so the
# existing Spotify creds/identity/library keep working); /data/rooms holds new rooms.
mkdir -p /data/go-librespot /data/owntone /data/rooms /srv/media /srv/media/rooms /root/.config
chmod 0755 /srv/media
chown -R owntone:owntone /data/owntone || true
# Room 0 keeps its legacy go-librespot config dir reachable at the default ~/.config path.
ln -sfn /data/go-librespot /root/.config/go-librespot

# Restrict mDNS advertising to the real LAN interface (avoid dead docker0/hassio/veth IPs).
IFACE="$(jq -r '.network_interface // ""' "$OPTS")"
if [ -z "$IFACE" ]; then
  IFACE="$(ip route show default 2>/dev/null | awk '/default/ {print $5; exit}')"
fi
if [ -n "$IFACE" ] && [ -f /etc/avahi/avahi-daemon.conf ]; then
  sed -i '/^allow-interfaces=/d' /etc/avahi/avahi-daemon.conf
  sed -i "/^\[server\]/a allow-interfaces=${IFACE}" /etc/avahi/avahi-daemon.conf
  bashio::log.info "mDNS restricted to interface '${IFACE}'"
else
  bashio::log.info "mDNS interface restriction: none (advertising on all interfaces)"
fi

# Pin a STABLE, distinct mDNS host-name. The container's auto hostname (e.g. "<hash>-podconnect")
# collided on the LAN and avahi looped renaming "...-16, -17, -18…" (withdrawing/re-registering the
# host address record every ~20s = constant churn). Claiming our own name avoids that conflict, and
# stays off the HA host's identity. Worst case (name still taken) = same rename behaviour as before.
if [ -f /etc/avahi/avahi-daemon.conf ]; then
  sed -i '/^host-name=/d' /etc/avahi/avahi-daemon.conf
  sed -i "/^\[server\]/a host-name=podconnect" /etc/avahi/avahi-daemon.conf
  bashio::log.info "mDNS host-name pinned to 'podconnect'"

  # Raise avahi's per-client object ceiling. OwnTone's AirPlay browsing creates many avahi objects
  # (resolvers/browsers per discovered device); on a busy LAN it hit the default cap and avahi logged
  # "dbus: Too many objects for client" + failed requests. Raising the limit removes the failures.
  # Safe: it only lifts a ceiling. (Unknown key would just be ignored by avahi.)
  sed -i '/^objects-per-client-max=/d' /etc/avahi/avahi-daemon.conf
  sed -i "/^\[server\]/a objects-per-client-max=65536" /etc/avahi/avahi-daemon.conf
  bashio::log.info "mDNS objects-per-client-max raised to 65536"
fi

bashio::log.info "PodConnect global setup done — manager will render + supervise rooms"
